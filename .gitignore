# build artifacts (regenerable)
DX_studies/build/
Build/
DerivedData/
# runtime outputs (keep the folder, ignore generated files)
DX_studies/output/*
!DX_studies/output/.gitkeep
!DX_studies/output/cam_intrinsic_prameters_test.yml
# macOS / editor
.DS_Store
*.xcuserstate
xcuserdata/
Thumbs.db
*.exe
# color-threshold state, auto-generated per run/environment (mode 5 で各自調整)
cam0_*.yml
# ただし output/ のリファレンス(基準値)は同梱して追跡する（各自 mode 5 で上書き可能）
!DX_studies/output/cam0_ori.yml
!DX_studies/output/cam0_oth.yml
!DX_studies/output/cam0_tgt.yml
