{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenGLApp (Windows MSYS2)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/DX_studies/build/OpenGLApp.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/DX_studies",
      "environment": [
        { "name": "PATH", "value": "C:/msys64/mingw64/bin;${env:PATH}" }
      ],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
      "preLaunchTask": "build OpenGL project",
      "setupCommands": [
        { "description": "Enable pretty-printing for gdb", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ]
    }
  ]
}
